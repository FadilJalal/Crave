# ═══════════════════════════════════════════════════════════════════════════════
# CRAVE BACKEND CONFIGURATION
# Copy this file to .env and fill in the values
# ═══════════════════════════════════════════════════════════════════════════════

# REQUIRED: MongoDB Connection
# Tutorial: https://www.mongodb.com/docs/manual/reference/connection-string/
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/crave?retryWrites=true&w=majority

# REQUIRED: JWT Secret for authentication
# Generate: Use any strong random string (min 32 characters)
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_random

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL: AI Features (Groq Real AI Integration)
# ═══════════════════════════════════════════════════════════════════════════════

# Get free Groq API key: https://console.groq.com/keys
# No credit card needed, completely free tier
# Features: AI Menu Optimizer, Real AI Recommendations
GROQ_API_KEY=gsk_your_api_key_here

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL: Server Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# Port for backend server
PORT=4000

# Allowed CORS origins (comma-separated)
# Example: http://localhost:5173,http://localhost:5174,https://crave.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL: Email Configuration (for password reset, campaigns)
# ═══════════════════════════════════════════════════════════════════════════════

# SMTP settings for NodeMailer
SMTP_SERVICE=gmail
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ═══════════════════════════════════════════════════════════════════════════════
# SETUP INSTRUCTIONS
# ═══════════════════════════════════════════════════════════════════════════════

# 1. Copy this file to .env (same directory):
#    cp .env.example .env
#
# 2. Fill in MONGO_URL (required):
#    - Go to https://www.mongodb.com
#    - Create account and cluster
#    - Copy connection string
#
# 3. Fill in JWT_SECRET (required):
#    - Use any strong random string (min 32 chars)
#    - Example: "aB3$xYz9@mK2#pL7&vQ4!nJ8^wR5*tS6"
#
# 4. (OPTIONAL) For AI Features - Fill in GROQ_API_KEY:
#    - Go to https://console.groq.com/keys
#    - Sign up (free, no credit card)
#    - Create API key
#    - Paste here
#    - Restart backend after adding key
#
# 5. Start backend:
#    npm run server
#
# Note: Keep this .env file PRIVATE! Never commit to git or share.
